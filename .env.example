# Environment Variables for Gateway Manager

Create a `.env` file based on this template.

# Path to the JSON file containing VLESS keys
KEYS_JSON_PATH=docs/keys.json

# Path where Xray configuration will be generated
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json

# Timeout for checking VLESS server connectivity (seconds)
CHECK_TIMEOUT=5.0

# Interval between connectivity checks (seconds)
CHECK_INTERVAL=10.0

# Shadowsocks-2022 Inbound Settings
# Port for the Shadowsocks service
SS_INBOUND_PORT=8388
# Password for Shadowsocks
SS_PASSWORD=your_secure_password_here
# Method (e.g., 2022-blake3-aes-128-gcm)
SS_METHOD=2022-blake3-aes-128-gcm
