# Environment Variables for Gateway Manager
# Copy this file to .env and customize for your setup

# ============================================
# PATHS AND BASIC SETTINGS
# ============================================

# Path to the JSON file containing VLESS keys
KEYS_JSON_PATH=docs/keys.json

# Path where Xray configuration will be generated
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json

# Timeout for checking VLESS server connectivity (seconds)
CHECK_TIMEOUT=5.0

# Interval between connectivity checks (seconds)
CHECK_INTERVAL=10.0

# ============================================
# GATEWAY MODE
# ============================================

# Operation mode: 'single' or 'multi'
# - 'single': One VLESS outbound, one active key at a time (with auto-rotation)
# - 'multi': Multiple VLESS outbounds, all clients connected simultaneously
GATEWAY_MODE=single

# ============================================
# SHADOWSOCKS-2022 INBOUND SETTINGS
# ============================================

# Port for the Shadowsocks service
SS_INBOUND_PORT=8388

# Password for Shadowsocks (must be 16 bytes for 2022-blake3-aes-128-gcm)
# Generate with: openssl rand -base64 16
SS_PASSWORD=your_secure_password_here

# Method (e.g., 2022-blake3-aes-128-gcm, aes-256-gcm)
SS_METHOD=2022-blake3-aes-128-gcm

# VPS IP address for Shadowsocks outbound (required for key generation)
# Get your public IP with: curl ifconfig.me
VPS_IP=YOUR_VPS_IP_ADDRESS

# ============================================
# KEY SOURCE MODE
# ============================================

# Key source mode: 'keys_json' or 'direct_internet'
# - 'keys_json': Get best key from KEYS_JSON_PATH (docs/keys.json)
# - 'direct_internet': Use direct freedom outbound (no proxy, direct internet)
# Default: keys_json
KEY_SOURCE_MODE=keys_json

# ============================================
# MULTI-CLIENT SETUP (GATEWAY_MODE=multi)
# ============================================

# Comma-separated list of UUIDs for each client
# Example: CLIENT_UUIDS=uuid1,uuid2,uuid3
# Generate UUIDs with: python3 -c "import uuid; print(uuid.uuid4())"
CLIENT_UUIDS=

# Comma-separated list of VLESS keys for each client (must match UUID count)
# Example: CLIENT_KEYS=key1,key2,key3
# Format: vless://UUID@IP:PORT?security=TLS|REALITY&encryption=none&flow=xtls-rprx-vision&sni=DOMAIN
CLIENT_KEYS=

# ============================================
# XRAY OUTBOUND SETTINGS
# ============================================

# Network type for outbound connections: tcp, xhttp, ws, grpc
XRAY_OUTBOUND_NETWORK=tcp

# Security type: tls, reality, none
# Note: This is used as fallback if not specified in the VLESS key
XRAY_SECURITY=tls

# Xray inbound SOCKS5 port (default 1080)
XRAY_INBOUND_SOCKS_PORT=1080

# ============================================
# CHAIN VLESS CONFIGURATION
# ============================================

# Chain VLESS key for explicit routing (Client -> VPS -> Second VLESS)
# This creates a chain outbound that all traffic goes through
# Format: vless://UUID@IP:PORT?security=TLS|REALITY&encryption=none&flow=xtls-rprx-vision&sni=DOMAIN
# CHAIN_VLESS_KEY=vless://...your_chain_vless_key...

# Chain outbound tag (for explicit routing in chain configurations)
CHAIN_OUTBOUND_TAG=chain-vless-out

# ============================================
# WARP PROXY CONFIGURATION (for ChatGPT access)
# ============================================

# Cloudflare WARP SOCKS5 port (default: 40000)
# Before enabling, install and configure WARP on VPS:
#   warp-cli mode proxy
#   warp-cli connect
WARP_SOCKS_PORT=40000

# Domains to route through WARP (comma-separated)
WARP_DOMAINS=openai.com,chatgpt.com,ai.com

# ============================================
# IPv6 CONFIGURATION
# ============================================

# Enable IPv6 blocking (true/false)
# When enabled, all IPv6 traffic is routed to blackhole to prevent leaks
# Recommended: true (to prevent IP leaks)
ENABLE_IPV6_BLOCK=true

# ============================================
# REMOVED (Unused)
# ============================================

# XRAY_INBOUND_DNS_PORT=1081  # Removed - not used in gateway_manager.py
