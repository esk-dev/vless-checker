# Environment Variables for Gateway Manager

Create a `.env` file based on this template.

# ============================================
# PATHS AND BASIC SETTINGS
# ============================================

# Path to the JSON file containing VLESS keys
KEYS_JSON_PATH=docs/keys.json

# Path where Xray configuration will be generated
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json

# Timeout for checking VLESS server connectivity (seconds)
CHECK_TIMEOUT=5.0

# Interval between connectivity checks (seconds)
CHECK_INTERVAL=10.0

# ============================================
# GATEWAY MODE
# ============================================

# Operation mode: 'single' or 'multi'
# - 'single': One VLESS outbound, one active key at a time
# - 'multi': Multiple VLESS outbounds, all clients connected simultaneously
GATEWAY_MODE=single

# ============================================
# SHADOWSOCKS-2022 INBOUND SETTINGS
# ============================================

# Port for the Shadowsocks service
SS_INBOUND_PORT=8388

# Password for Shadowsocks (must be 16 bytes for 2022-blake3-aes-128-gcm)
# Generate with: openssl rand -base64 16
SS_PASSWORD=your_secure_password_here

# Method (e.g., 2022-blake3-aes-128-gcm, aes-256-gcm)
SS_METHOD=2022-blake3-aes-128-gcm

# ============================================
# MULTI-CLIENT SETUP (GATEWAY_MODE=multi)
# ============================================

# Comma-separated list of UUIDs for each client
# Example: CLIENT_UUIDS=uuid1,uuid2,uuid3
# Generate UUIDs with: python3 -c "import uuid; print(uuid.uuid4())"
CLIENT_UUIDS=4b056394-2f40-11f1-bffe-46c4782ac1a7

# Example VLESS key for server 77.233.215.78
# Format: vless://UUID@IP:PORT?security=TLS|REALITY&encryption=none&flow=xtls-rprx-vision&sni=DOMAIN
CLIENT_KEYS=vless://4b056394-2f40-11f1-bffe-46c4782ac1a7@77.233.215.78:443?security=tls&encryption=none&flow=xtls-rprx-vision&sni=example.com

# ============================================
# XRAY OUTBOUND SETTINGS
# ============================================

# Network type for outbound connections: tcp, xhttp, ws, grpc
XRAY_OUTBOUND_NETWORK=tcp

# Security type: tls, reality, none
XRAY_SECURITY=tls

# Xray inbound SOCKS5 port (default 1080)
XRAY_INBOUND_SOCKS_PORT=1080

# Xray inbound DNS port (optional, for DNS routing)
# XRAY_INBOUND_DNS_PORT=1081
