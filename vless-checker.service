[Unit]
Description=VLESS Key Checker Task
After=network.target

[Service]
Type=oneshot
# Убедитесь, что путь ниже соответствует вашему реальному пути к проекту
WorkingDirectory=/home/developer/vless-checker
ExecStart=/home/developer/bin/python3 /home/developer/vless-checker/check_and_save.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
